def is_private_chat(message):
    return message.chat.type == 'private'

def should_respond_to_text(message):
    text = message.text or ""
    
    if is_private_chat(message):
        return True
    
    if text.strip().startswith('&'):
        return True
    
    if message.reply_to_message and message.reply_to_message.from_user.id == bot.bot_id:
        return True
    
    return False

def remove_trigger_symbol(text):
    text = text.strip()
    if text.startswith('&'):
        return text[1:].strip()
    return text

@bot.message_handler(func=lambda m: True)
async def handle_logic(message):
    chat_id = message.chat.id
    user_id = message.from_user.id
    
    if not should_respond_to_text(message):
        return
    
    if user_id in blocked_users:
        return
    
    if check_spam(chat_id):
        return
    
    if chat_id not in user_stats:
        user_stats[chat_id] = {"messages": 0, "roasts": 0, "commands": 0}
    user_stats[chat_id]["messages"] = user_stats[chat_id].get("messages", 0) + 1
    user_last_message[chat_id] = time.time()
    
    if chat_id not in user_context:
        user_context[chat_id] = []
    
    msg_text = message.text or ""
    msg_text = remove_trigger_symbol(msg_text)
    msg_text = clean_text(msg_text)
    
    if not msg_text:
        await bot.reply_to(message, "чё пустое сообщение то прислал дебил")
        return
    
    user_context[chat_id].append({"role": "user", "content": msg_text})
    user_context[chat_id] = user_context[chat_id][-7:]
    
    await bot.send_chat_action(chat_id, 'typing')
    
    try:
        messages = [{"role": "system", "content": DANIL_ROLE}] + user_context[chat_id]
        
        # Получаем ответ от Groq
        answer, source = await get_ai_response(messages)
        
        # Если Groq не ответил — заглушка
        if not answer:
            answer = "бля головой об стену бился чтоли такую хуйню спрашивать"
            source = "local" 
        
        user_context[chat_id].append({"role": "assistant", "content": answer})
        
        print(f"✅ Ответ от {source}: {answer[:50]}...")
        
        await asyncio.sleep(0.5 + random.random() * 0.5)
        try:
            await bot.reply_to(message, answer, parse_mode='Markdown')
        except:
            await bot.reply_to(message, answer)
            
    except Exception as e:
        print(f"❌ Ошибка в handle_logic: {e}")
        import traceback
        traceback.print_exc()
        await bot.reply_to(message, "бля чё-то сломалось ну чё поделать")

async def main():
    await setup_commands()
    me = await bot.get_me()
    print("=" * 50)
    print(f"✅ Данил 5.0 с Groq запущен!")
    print(f"Бот: @{me.username}")
    print(f"Groq доступен: {GROQ_AVAILABLE}")
    print("=" * 50)
    await bot.polling(non_stop=True)

if __name__ == '__main__':
    asyncio.run(main())
