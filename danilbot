# === HELPERS ===
def get_user(user_id, username, first_name):
    cursor.execute("SELECT * FROM users WHERE user_id=?", (user_id,))
    user = cursor.fetchone()
    if not user:
        cursor.execute(
            "INSERT INTO users (user_id, username, first_name, total_tapoks, last_tapok, refs, ref_by, balance, cooldown_level, bonus_level) VALUES (?,?,?,?,?,?,?,?,?,?)",
            (user_id, username or "", first_name or "", 0, 0, 0, 0, 0, 0, 0)
        )
        conn.commit()
    return cursor.execute("SELECT * FROM users WHERE user_id=?", (user_id,)).fetchone()

def get_chat(chat_id, title):
    cursor.execute("SELECT * FROM chats WHERE chat_id=?", (chat_id,))
    chat = cursor.fetchone()
    if not chat:
        cursor.execute("INSERT INTO chats (chat_id, chat_title) VALUES (?,?)", (chat_id, title or "Чат"))
        conn.commit()
    return cursor.execute("SELECT * FROM chats WHERE chat_id=?", (chat_id,)).fetchone()

def format_time(seconds):
    if seconds <= 0:
        return "сейчас"
    m, s = divmod(int(seconds), 60)
    h, m = divmod(m, 60)
    parts = []
    if h: parts.append(f"{h} ч.")
    if m: parts.append(f"{m} мин.")
    if s: parts.append(f"{s} сек.")
    return " ".join(parts)

def get_cooldown(user_id):
    cursor.execute("SELECT cooldown_level FROM users WHERE user_id=?", (user_id,))
    result = cursor.fetchone()
    lvl = result[0] if result else 0
    return COOLDOWN_LEVELS.get(lvl, COOLDOWN_LEVELS[0])["time"]

def get_multiplier(user_id):
    cursor.execute("SELECT bonus_level FROM users WHERE user_id=?", (user_id,))
    result = cursor.fetchone()
    lvl = result[0] if result else 0
    return BONUS_LEVELS.get(lvl, BONUS_LEVELS[0])["multiplier"]

# === CHECK MESSAGE OWNER ===
def check_owner(update: Update):
    """Returns True if the callback query user is the message owner"""
    if not update.callback_query:
        return True
    query = update.callback_query
    # Get the user who sent the original message
    msg_user_id = query.message.from_user.id if query.message and query.message.from_user else None
    # Get the user who clicked the button
    clicker_id = query.from_user.id
    return msg_user_id == clicker_id

