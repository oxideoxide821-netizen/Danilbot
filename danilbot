def load():
    return json.load(open(DATA_FILE, "r", encoding="utf-8")) if os.path.exists(DATA_FILE) else {"chats": {}}

def save(d):
    json.dump(d, open(DATA_FILE, "w", encoding="utf-8"), ensure_ascii=False, indent=2)

def ensure_fields(ud):
    defaults = {"grass": 0, "smoked": 0, "xp": 0, "lvl": 1, "last": 0, "name": "", "clocks": 0, "bonus": "", "tobacco": 0, "coins": 0, "cigarettes": 0}
    for k, v in defaults.items():
        if k not in ud: ud[k] = v
    return ud

def get_user(d, uid, cid):
    c, u = str(cid), str(uid)
    d["chats"].setdefault(c, {})
    d["chats"][c].setdefault(u, {})
    d["chats"][c][u] = ensure_fields(d["chats"][c][u])
    return d["chats"][c][u]

def get_cd(ud):
    reduction = (ud["lvl"] - 1) * 120
    return max(BASE_COOLDOWN - reduction, MIN_COOLDOWN)

def fmt(t):
    return f"{int(t//3600)}ч {int(t%3600//60)}м" if t >= 3600 else f"{int(t//60)}м {int(t%60)}с" if t >= 60 else f"{int(t)}с"

def lvl_up(ud):
    while ud["xp"] >= ud["lvl"] * 10:
        ud["xp"] -= ud["lvl"] * 10; ud["lvl"] += 1
    return ud["lvl"]

def rank(d, cid, uid):
    c = d["chats"].get(str(cid), {})
    s = sorted(c.items(), key=lambda x: (x[1].get("smoked", 0), x[1].get("lvl", 1)), reverse=True)
    for i, (k, _) in enumerate(s, 1):
        if int(k) == uid: return f"#{i}"
    return "?"

def decl_grass(n):
    if 11 <= n % 100 <= 14: return "грамм"
    elif n % 10 == 1: return "грамм"
    elif 2 <= n % 10 <= 4: return "грамма"
    else: return "грамм"

def decl_cigarettes(n):
    if 11 <= n % 100 <= 14: return "сигарет"
    elif n % 10 == 1: return "сигарета"
    elif 2 <= n % 10 <= 4: return "сигареты"
    else: return "сигарет"

def parse_duration(text):
    text = text.strip().lower().replace(" ", "")
    match = re.match(r'(\d+)([чмсд]?)', text)
    if not match: return None
    num = int(match.group(1))
    unit = match.group(2)
    if unit == 'ч': return num * 3600
    elif unit == 'д': return num * 86400
    elif unit == 'с': return num
    else: return num * 60

