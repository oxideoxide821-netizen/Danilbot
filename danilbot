def clean_text(text):
    """Очищает знаки препинания как в оригинале"""
    text = text.replace(".", "").replace(",", "").replace("!", "").replace("?", "")
    text = text.replace(";", "").replace(":", "").replace("-", "").replace("—", "")
    text = text.replace("(", "").replace(")", "").replace("\"", "").replace("'", "")
    text = " ".join(text.split())
    return text.lower()

def format_code_properly(text):
    """Улучшенное форматирование кода для копирования"""
    code_block_pattern = r'```(\w*)\n(.*?)```'
    matches = list(re.finditer(code_block_pattern, text, re.DOTALL))
    
    if matches:
        for match in matches:
            lang = match.group(1)
            code = match.group(2)
            lines = code.split('\n')
            min_indent = float('inf')
            for line in lines:
                if line.strip():
                    indent = len(line) - len(line.lstrip())
                    min_indent = min(min_indent, indent)
            if min_indent > 0 and min_indent != float('inf'):
                lines = [line[min_indent:] if line.strip() else line for line in lines]
                code = '\n'.join(lines)
            new_block = f'```{lang}\n{code}\n```'
            text = text.replace(match.group(0), new_block)
    else:
        lines = text.split('\n')
        result_lines = []
        code_buffer = []
        in_code = False
        
        for line in lines:
            is_code_line = (
                line.strip().startswith(('def ', 'class ', 'import ', 'from ', 'return ', 'if ', 'for ', 'while ', 'try:', 'except:', 'async ', 'await ', 'const ', 'let ', 'var ', 'function ', '=>', '{', '}', '//', '#', '/*', '*/', '<', '>', '$', 'npm ', 'pip ', 'git ', 'docker ', 'kubectl ')) or
                re.match(r'^\s+[a-zA-Z_][a-zA-Z0-9_]*\s*[=:]\s*', line) or
                re.match(r'^\s*[\[\{]', line) or
                re.match(r'^\s*[a-zA-Z_][a-zA-Z0-9_]*\s*\(', line)
            )
            
            if is_code_line and not in_code:
                in_code = True
                if result_lines and result_lines[-1].strip():
                    result_lines.append('')
                code_buffer = [line]
            elif is_code_line and in_code:
                code_buffer.append(line)
            elif not is_code_line and in_code:
                in_code = False
                if code_buffer:
                    code_block = '\n'.join(code_buffer)
                    lang = ''
                    if any(l.strip().startswith(('import ', 'from ', 'def ', 'class ', 'async def')) for l in code_buffer):
                        lang = 'python'
                    elif any(l.strip().startswith(('const ', 'let ', 'var ', 'function ', '=>', '{')) for l in code_buffer):
                        lang = 'javascript'
                    elif '<' in code_block and '>' in code_block:
                        lang = 'html'
                    result_lines.append(f'```{lang}')
                    result_lines.append(code_block.strip())
                    result_lines.append('```')
                    code_buffer = []
                result_lines.append(line)
            else:
                result_lines.append(line)
        
        if code_buffer:
            lang = 'python' if any('def ' in l or 'import ' in l for l in code_buffer) else ''
            result_lines.append(f'```{lang}')
            result_lines.append('\n'.join(code_buffer).strip())
            result_lines.append('```')
        
        text = '\n'.join(result_lines)
    
    return text

async def ask_groq(messages):
    """Запрос к Groq API"""
    if not GROQ_AVAILABLE or not groq_client:
        print("❌ Groq не доступен")
        return None
    
    try:
        print("⏳ Отправляю запрос в Groq...")
        
        # Groq требует первое сообщение от 'user' или 'system', но не 'assistant'
        # Проверяем и фиксим если нужно
        groq_messages = []
        for msg in messages:
            groq_messages.append(msg)
        
        completion = groq_client.chat.completions.create(
            model="llama-3.3-70b-versatile",
            messages=groq_messages,
            temperature=0.9,  # Повышаем для более креативных ответов
            max_tokens=1024,
        )
        
        answer = completion.choices[0].message.content
        print(f"📨 Groq ответил: {answer[:100]}...")
        
        # Обрабатываем ответ
        answer = format_code_properly(answer)
        
        if len(answer.strip()) < 3:
            print("⚠️ Groq пустой ответ")
            return None
            
        print("✅ Groq ответ хороший")
        return answer
        
    except Exception as e:
        print(f"❌ Groq ошибка: {type(e).__name__}: {e}")
        return None

async def get_ai_response(messages):
    """
    Получает ответ от ИИ через Groq
    """
    answer = await ask_groq(messages)
    
    if answer:
        return answer, "Groq"
    
    # Если Groq не сработал — заглушка
    print("⚠️ Groq не ответил, использую заглушку")
    return None, "error"

def check_spam(chat_id):
    current_time = time.time()
    if chat_id in cooldown_users:
        last_time = cooldown_users[chat_id]
        if current_time - last_time < 1:
            return True
    cooldown_users[chat_id] = current_time
    return False

