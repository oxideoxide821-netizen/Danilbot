_data_cache = None
_data_dirty = False


def load():
    global _data_cache
    if _data_cache is not None:
        return _data_cache
    if os.path.exists(DATA_FILE):
        try:
            with open(DATA_FILE, "r", encoding="utf-8") as f:
                _data_cache = json.load(f)
                if not isinstance(_data_cache, dict):
                    _data_cache = {"chats": {}}
                if "chats" not in _data_cache:
                    _data_cache["chats"] = {}
                return _data_cache
        except Exception as e:
            logger.error(f"Load error: {e}")
            _data_cache = {"chats": {}}
            return _data_cache
    _data_cache = {"chats": {}}
    return _data_cache


def save(d=None):
    global _data_cache, _data_dirty
    if d is None:
        d = _data_cache
    _data_cache = d
    _data_dirty = True
    try:
        with open(DATA_FILE, "w", encoding="utf-8") as f:
            json.dump(d, f, ensure_ascii=False, indent=2)
        _data_dirty = False
    except Exception as e:
        logger.error(f"Save error: {e}")


def force_save():
    global _data_cache, _data_dirty
    if _data_cache is not None and _data_dirty:
        try:
            with open(DATA_FILE, "w", encoding="utf-8") as f:
                json.dump(_data_cache, f, ensure_ascii=False, indent=2)
            _data_dirty = False
            logger.info("Auto-save completed")
        except Exception as e:
            logger.error(f"Force save error: {e}")


def ensure_fields(ud):
    defaults = {
        "grass": 0, "smoked": 0, "xp": 0, "lvl": 1, "last": 0, "name": "",
        "clocks": 0, "bonus": "", "tobacco": 0, "coins": 0, "cigarettes": 0,
        "cigars": 0, "farm": 0, "farm_last": 0, "fast_farm": 0,
        "fast_farm_last": 0, "last_grass_type": "обычная", "is_bot": False
    }
    changed = False
    for k, v in defaults.items():
        if k not in ud:
            ud[k] = v
            changed = True
    return ud, changed


def get_user(d, uid, cid):
    c, u = str(cid), str(uid)
    d.setdefault("chats", {})
    d["chats"].setdefault(c, {})
    d["chats"][c].setdefault(u, {})
    ud, changed = ensure_fields(d["chats"][c][u])
    d["chats"][c][u] = ud
    if changed:
        save(d)
    return ud


def get_cd(ud):
    reduction = (ud["lvl"] - 1) * 120
    return max(BASE_COOLDOWN - reduction, MIN_COOLDOWN)


def fmt(t):
    if t >= 3600:
        return f"{int(t//3600)}ч {int(t%3600//60)}м"
    elif t >= 60:
        return f"{int(t//60)}м {int(t%60)}с"
    return f"{int(t)}с"


def lvl_up(ud):
    while ud["xp"] >= ud["lvl"] * 10:
        ud["xp"] -= ud["lvl"] * 10
        ud["lvl"] += 1
    return ud["lvl"]


def rank(d, cid, uid):
    c = d["chats"].get(str(cid), {})
    filtered = {k: v for k, v in c.items() if not v.get("is_bot", False)}
    s = sorted(filtered.items(), key=lambda x: (x[1].get("smoked", 0), x[1].get("lvl", 1)), reverse=True)
    for i, (k, _) in enumerate(s, 1):
        if int(k) == uid:
            return f"#{i}"
    return "?"


