# === TAPOK ===
async def do_tapok(update: Update, context: ContextTypes.DEFAULT_TYPE):
    chat_id = update.effective_chat.id
    user_id = update.effective_user.id
    username = update.effective_user.username
    first_name = update.effective_user.first_name
    chat_title = update.effective_chat.title
    
    user = get_user(user_id, username, first_name)
    get_chat(chat_id, chat_title)
    
    now = time.time()
    cooldown = get_cooldown(user_id)
    multiplier = get_multiplier(user_id)
    
    cursor.execute("SELECT last_used FROM cooldowns WHERE user_id=? AND chat_id=?", (user_id, chat_id))
    cd = cursor.fetchone()
    last_used = cd[0] if cd else 0
    
    remaining = cooldown - (now - last_used)
    
    if remaining > 0:
        text = f"⏳ <b>{first_name}</b>, подожди ещё {format_time(remaining)}\nВсего тапков — <b>{user[3]:.2f}</b> см."
        if update.callback_query:
            await update.callback_query.edit_message_text(text, parse_mode="HTML")
        else:
            await update.message.reply_text(text, parse_mode="HTML")
        return
    
    base_tapok = round(random.uniform(0.5, 5.0), 2)
    tapok_size = round(base_tapok * multiplier, 2)
    
    cursor.execute("UPDATE users SET total_tapoks = total_tapoks + ?, last_tapok = ? WHERE user_id=?",
                   (tapok_size, now, user_id))
    cursor.execute("UPDATE users SET balance = balance + ? WHERE user_id=?", (int(tapok_size * 10), user_id))
    cursor.execute("UPDATE chats SET total_tapoks = total_tapoks + ? WHERE chat_id=?", (tapok_size, chat_id))
    cursor.execute("INSERT OR REPLACE INTO cooldowns (user_id, chat_id, last_used) VALUES (?,?,?)",
                   (user_id, chat_id, now))
    conn.commit()
    
    user = cursor.execute("SELECT * FROM users WHERE user_id=?", (user_id,)).fetchone()
    
    messages = [
        f"💥 <b>{first_name}</b>, получил(а) тапок <b>{tapok_size}</b> см по жопе!\nВсего тапков — <b>{user[3]:.2f}</b> см.",
        f"👋 <b>{first_name}</b>, раздался хлопок! Тапок <b>{tapok_size}</b> см!\nОбщий счёт — <b>{user[3]:.2f}</b> см.",
        f"🩴 <b>{first_name}</b>, жопа горит! Тапок на <b>{tapok_size}</b> см!\nНакоплено — <b>{user[3]:.2f}</b> см.",
    ]
    
    keyboard = [[InlineKeyboardButton("🩴 Ещё тапок!", callback_data="tapok")]]
    reply_markup = InlineKeyboardMarkup(keyboard)
    
    msg = random.choice(messages)
    if update.callback_query:
        await update.callback_query.edit_message_text(msg, parse_mode="HTML", reply_markup=reply_markup)
    else:
        await update.message.reply_text(msg, parse_mode="HTML", reply_markup=reply_markup)

