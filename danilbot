# === START HANDLER FOR REFS ===
async def start_ref(update: Update, context: ContextTypes.DEFAULT_TYPE):
    if update.effective_chat.type != "private":
        await start(update, context)
        return
    
    args = context.args
    user_id = update.effective_user.id
    username = update.effective_user.username
    first_name = update.effective_user.first_name
    
    get_user(user_id, username, first_name)
    
    if args and args[0].isdigit():
        ref_id = int(args[0])
        if ref_id != user_id:
            cursor.execute("SELECT * FROM users WHERE user_id=?", (ref_id,))
            ref_user = cursor.fetchone()
            if ref_user:
                cursor.execute("UPDATE users SET balance = balance + 1000 WHERE user_id=?", (ref_id,))
                cursor.execute("UPDATE users SET refs = refs + 1 WHERE user_id=?", (ref_id,))
                cursor.execute("UPDATE users SET ref_by = ? WHERE user_id=?", (ref_id, user_id))
                conn.commit()
                await context.bot.send_message(
                    ref_id,
                    f"🎉 <b>{first_name}</b> присоединился по твоей ссылке!\nТебе начислено <b>+1000</b> монет!",
                    parse_mode="HTML"
                )
    
    await update.message.reply_text(
        "🩴 <b>Тапкометр</b>\n\nБот-линейка для групп. Добавь меня в чат и пиши <b>тапок</b>!\n\nМои команды — <b>помощь</b>",
        parse_mode="HTML"
    )

