async def trade_start(u: Update, c: ContextTypes.DEFAULT_TYPE):
    if not await check_group(u): return
    d = load(); ud = get_user(d, u.effective_user.id, u.effective_chat.id)
    if ud.get("clocks", 0) < 1:
        await reply_and_delete(u, "⏱️ У тебя нет Часов травника для обмена!")
        return save(d)
    if not u.message.reply_to_message:
        await reply_and_delete(u, "❌ Ответь на сообщение пользователя, которому хочешь отправить часы!")
        return save(d)
    target = u.message.reply_to_message.from_user
    if target.id == u.effective_user.id:
        await reply_and_delete(u, "🤡 Нельзя трейдить самому себе!")
        return save(d)
    if target.is_bot:
        await reply_and_delete(u, "🤖 Нельзя трейдить с ботами!")
        return save(d)
    cid = str(u.effective_chat.id)
    TRADE_STATE.setdefault(cid, {})
    TRADE_STATE[cid][str(u.effective_user.id)] = {"to_id": target.id, "clocks": 1}
    await reply_and_delete(u, "🤝 Трейд\n\nТы предлагаешь обменять 1 ⏱️ Часы травника пользователю " + target.first_name + "!\n\n" + target.first_name + ", напиши 'принять трейд', чтобы получить часы!")
    save(d)

async def trade_accept(u: Update, c: ContextTypes.DEFAULT_TYPE):
    if not await check_group(u): return
    cid = str(u.effective_chat.id); uid = str(u.effective_user.id)
    if cid not in TRADE_STATE:
        await reply_and_delete(u, "❌ Нет активных трейдов!")
        return
    found = None
    for from_id, info in TRADE_STATE[cid].items():
        if str(info["to_id"]) == uid:
            found = (from_id, info)
            break
    if not found:
        await reply_and_delete(u, "❌ Никто не предлагал тебе трейд!")
        return
    from_id, info = found
    d = load()
    from_ud = get_user(d, int(from_id), u.effective_chat.id)
    to_ud = get_user(d, u.effective_user.id, u.effective_chat.id)
    if from_ud.get("clocks", 0) < info["clocks"]:
        await reply_and_delete(u, "❌ У отправителя больше нет часов! Трейд отменён.")
        del TRADE_STATE[cid][from_id]
        return save(d)
    from_ud["clocks"] -= info["clocks"]; to_ud["clocks"] += info["clocks"]
    from_ud["name"] = from_ud.get("name", "Игрок")
    to_ud["name"] = u.effective_user.username or u.effective_user.first_name
    del TRADE_STATE[cid][from_id]
    save(d)
    await reply_and_delete(u, "🤝 Трейд завершён!\n\n" + from_ud["name"] + " → " + to_ud["name"] + "\n⏱️ Передано: 1 Часы травника")

async def trade_cancel(u: Update, c: ContextTypes.DEFAULT_TYPE):
    if not await check_group(u): return
    cid = str(u.effective_chat.id); uid = str(u.effective_user.id)
    if cid in TRADE_STATE and uid in TRADE_STATE[cid]:
        del TRADE_STATE[cid][uid]
        await reply_and_delete(u, "❌ Трейд отменён!")
    else:
        await reply_and_delete(u, "❌ У тебя нет активных трейдов!")

async def is_admin(chat, user_id):
    try:
        member = await chat.get_member(user_id)
        return member.status in ["creator", "administrator"]
    except:
        return False

async def ban(u: Update, c: ContextTypes.DEFAULT_TYPE):
    if not await check_group(u): return
    chat, user = u.effective_chat, u.effective_user
    if not await is_admin(chat, user.id):
        return await reply_and_delete(u, "❌ Только админы!")
    if not u.message.reply_to_message: return await reply_and_delete(u, "❌ Ответь на сообщение!")
    t = u.message.reply_to_message.from_user
    if t.id == user.id: return await reply_and_delete(u, "🤡 Нельзя забанить себя!")
    if t.is_bot: return await reply_and_delete(u, "🤖 Нельзя забанить бота!")
    if await is_admin(chat, t.id): return await reply_and_delete(u, "👮 Нельзя забанить админа!")
    try:
        try:
            member = await chat.get_member(t.id)
            if member.status == "kicked":
                return await reply_and_delete(u, "⚠️ " + t.first_name + " уже забанен!")
        except:
            pass
        await chat.ban_member(t.id)
        await reply_and_delete(u, "🚫 " + t.first_name + " забанен! Причина: курил слишком много 🌿")
    except Exception as e: await reply_and_delete(u, "❌ Ошибка: " + str(e))

