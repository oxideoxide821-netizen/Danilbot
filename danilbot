def parse_duration(text):
    text = text.strip().lower().replace(" ", "")
    match = re.match(r'(\d+)([чмсд]?)', text)
    if not match:
        return None
    num = int(match.group(1))
    unit = match.group(2)
    if unit == 'ч':
        return num * 3600
    elif unit == 'д':
        return num * 86400
    elif unit == 'с':
        return num
    return num * 60


def parse_number(text):
    match = re.search(r'(\d+)', text)
    if match:
        return int(match.group(1))
    return None


async def is_owner(user_id):
    return user_id in OWNER_IDS


async def auto_delete(msg, delay=AUTO_DELETE_DELAY):
    try:
        await asyncio.sleep(delay)
        await msg.delete()
    except:
        pass


async def reply_and_delete(u, text, delete_user_msg=True):
    bot_msg = await u.message.reply_text(text)
    asyncio.create_task(auto_delete(bot_msg))
    if delete_user_msg:
        asyncio.create_task(auto_delete(u.message, delay=AUTO_DELETE_DELAY))
    return bot_msg


