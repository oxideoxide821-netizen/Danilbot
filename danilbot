        return
    t = u.message.text.lower().strip()
    cmds = {
        "собрать": collect, "травка": collect, "собери": collect, "найти": collect,
        "курить": smoke, "курю": smoke, "дым": smoke, "затянуться": smoke, "закурить": smoke,
        "крафт": craft, "табак": craft, "сделать табак": craft,
        "профиль": profile, "я": profile, "стата": profile,
        "топ": top, "рейтинг": top, "лидеры": top,
        "инвентарь": inv, "инв": inv,
        "бонус": bonus, "ежедневный": bonus, "награда": bonus,
        "продать": sell, "продажа": sell, "продать траву": sell,
        "часы": check_clock, "кулдаун": check_clock, "время": check_clock,
        "использовать часы": use_clock, "юзать часы": use_clock, "применить часы": use_clock,
        "трейд": trade_start, "обмен": trade_start, "отправить часы": trade_start,
        "принять трейд": trade_accept, "принять": trade_accept,
        "отменить трейд": trade_cancel, "отмена трейд": trade_cancel,
        "ферма": farm, "собрать ферма": farm,
        "улучшить ферму": upgrade_farm, "апгрейд фермы": upgrade_farm,
        "бан": ban, "забанить": ban, "блок": ban,
        "анбан": unban, "разбан": unban, "разбанить": unban,
        "мут": mute, "замутить": mute, "заткнуть": mute,
        "анмут": unmute, "размут": unmute, "размутить": unmute,
        "помощь": start, "хелп": start, "команды": start, "старт": start, "начать": start,
    }
    if t in cmds:
        await cmds[t](u, c)
        return

    if t.startswith("ставка"):
        await bet(u, c)
        return
    if t.startswith("купить табак"):
        await buy_tobacco(u, c)
        return
    if t.startswith("купить сигарет"):
        await buy_cigarettes(u, c)
        return
    if t.startswith("купить сигар"):
        await buy_cigars(u, c)
        return
    if t.startswith("дать "):
        await give(u, c)
        return
    if t.startswith("закурить сигарет"):
        await smoke(u, c)
        return
    if t.startswith("закурить сигар"):
        await smoke(u, c)
        return

    if t in ["привет", "здарова", "ку", "хай", "йо"]:
        await u.message.reply_text("🌿 Здарова, " + u.effective_user.first_name + "! Напиши помощь, чтобы узнать команды!")
    elif t in ["пока", "бай", "до связи"]:
        await u.message.reply_text("👋 Пока, " + u.effective_user.first_name + "! Не забудь собрать травку перед уходом 🌿")

def main():
    app = Application.builder().token(BOT_TOKEN).build()
    app.add_handler(CommandHandler("start", start))
    app.add_handler(CommandHandler("help", start))
    app.add_handler(MessageHandler(filters.TEXT & ~filters.COMMAND, text))
    print("🌿 Травка Бот запущен!"); app.run_polling()

if __name__ == "__main__": main()
