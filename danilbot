async def collect(u: Update, c: ContextTypes.DEFAULT_TYPE):
    if not await check_group(u):
        return
    d = load()
    ud = get_user(d, u.effective_user.id, u.effective_chat.id)
    now = datetime.now().timestamp()
    cd = get_cd(ud)
    passed = now - ud["last"]
    if passed < cd:
        await reply_and_delete(u, f"⏳ Подожди ещё {fmt(cd - passed)}! Трава не растёт так быстро 🌿
Твой кулдаун: {fmt(cd)} (Lv.{ud['lvl']})")
        return save(d)
    r = random.randint(1, 100)
    gt = "обычная" if r <= 50 else "редкая" if r <= 80 else "эпическая" if r <= 95 else "легендарная" if r <= 99 else "божественная"
    g = GRASS[gt]
    amt = random.randint(1, 3)
    ud["grass"] += amt
    ud["xp"] += g["xp"]
    ud["last"] = now
    ud["name"] = u.effective_user.username or u.effective_user.first_name
    ud["last_grass_type"] = gt
    old = ud["lvl"]
    new = lvl_up(ud)
    clock_drop = ""
    if random.randint(1, 100) <= CLOCK_DROP_CHANCE:
        ud["clocks"] += 1
        clock_drop = f"

✨ РЕДКАЯ НАХОДКА!
⏱️ Ты нашёл Часы травника! (всего: {ud['clocks']})"
    save(d)
    decl = GRASS_DECL[gt]
    msg = f"{g['e']} Ты собрал {decl[0]} траву!
📦 Получено: {amt} {decl_grass(amt)}
⭐ Опыт: +{g['xp']} XP
🎒 Всего травы: {ud['grass']} гр"
    if new > old:
        msg += f"

🎉 УРОВЕНЬ ПОВЫШЕН!
Теперь ты {TITLES.get(new, '🌟 Уровень ' + str(new))}!"
    msg += clock_drop
    await reply_and_delete(u, msg)


