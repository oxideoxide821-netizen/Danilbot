async def mute(u: Update, c: ContextTypes.DEFAULT_TYPE):
    if not await check_group(u): return
    chat, user = u.effective_chat, u.effective_user
    if not await is_admin(chat, user.id):
        return await u.message.reply_text("❌ Только админы!")
    if not u.message.reply_to_message: return await u.message.reply_text("❌ Ответь на сообщение!")
    t = u.message.reply_to_message.from_user
    if t.id == user.id: return await u.message.reply_text("🤡 Нельзя замутить себя!")
    if t.is_bot: return await u.message.reply_text("🤖 Нельзя замутить бота!")
    if await is_admin(chat, t.id): return await u.message.reply_text("👮 Нельзя замутить админа!")
    try:
        member = await chat.get_member(t.id)
        if not member.permissions or not member.permissions.can_send_messages:
            return await u.message.reply_text("⚠️ " + t.first_name + " уже замучен!")
    except:
        pass
    dur = 3600
    text = u.message.text.lower().strip()
    rest = text.replace("мут", "").replace("замутить", "").replace("заткнуть", "").strip()
    if rest:
        parsed = parse_duration(rest)
        if parsed: dur = parsed
    try:
        await chat.restrict_member(t.id, until_date=datetime.now() + timedelta(seconds=dur), permissions={"can_send_messages": False, "can_send_media_messages": False, "can_send_other_messages": False, "can_add_web_page_previews": False})
        await u.message.reply_text("🔇 " + t.first_name + " замучен на " + fmt(dur) + "! Причина: слишком шумно курил 🌿")
    except Exception as e: await u.message.reply_text("❌ Ошибка: " + str(e))

